{
    "version": 4,
    "configurations": [
        {
            "name": "macOS",
            "compilerPath": "/usr/bin/clang++",
            "intelliSenseMode": "macos-clang-arm64",
            "cStandard": "c11",
            "cppStandard": "c++20",
            "compileCommands": "${workspaceFolder}/build/compile_commands.json",
            "includePath": [
                "${workspaceFolder}",
                "${workspaceFolder}/glsandbox/include",
                "${workspaceFolder}/third/glad/include",
                "${workspaceFolder}/third/glfw/include",
                "${workspaceFolder}/third/glm",
                "${workspaceFolder}/third/stb"
            ],
            "macFrameworkPath": [
                "/System/Library/Frameworks",
                "/Library/Frameworks"
            ]
        }
    ]
}